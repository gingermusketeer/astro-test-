---
import Layout from '../layouts/Layout.astro';
import tours from '../data/tours.json';
import testimonials from '../data/testimonials.json';

const whatsappUrl = "https://wa.me/261340000000";
const whatsappText = encodeURIComponent("Hello! I'm interested in booking a tour with Nosy Be Tours.");
---

<Layout title="Nosy Be Tours — Discover Madagascar's Hidden Gems">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content container">
      <span class="hero-badge">🌴 Nosy Be, Madagascar</span>
      <h1 class="hero-title">Discover Madagascar's<br />Hidden Gems</h1>
      <p class="hero-subtitle">
        Expert-guided tours through spice plantations, ancient baobab forests, and pristine island shores.
        Your adventure begins in Nosy Be.
      </p>
      <div class="hero-actions">
        <a href={`${whatsappUrl}?text=${whatsappText}`} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          💬 Chat on WhatsApp
        </a>
        <a href="#tours" class="btn btn-outline">View Our Tours</a>
      </div>
    </div>
    <div class="hero-scroll-hint">
      <span>Scroll to explore</span>
      <span class="scroll-arrow">↓</span>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section about-section" id="about">
    <div class="container about-grid">
      <div class="about-text">
        <span class="section-label">About Us</span>
        <h2 class="section-title">Your Local Guides<br />in Nosy Be</h2>
        <p>
          We are a small, passionate team of local guides born and raised in the Nosy Be archipelago.
          With deep knowledge of Madagascar's unique ecosystems, culture, and hidden corners, we craft
          authentic experiences that go far beyond the tourist trail.
        </p>
        <p>
          From the fragrant vanilla and cocoa plantations of the mainland to the baobab-studded
          landscapes of the west coast, every tour is designed to connect you with the real Madagascar.
        </p>
        <div class="about-stats">
          <div class="stat">
            <span class="stat-number">500+</span>
            <span class="stat-label">Happy Travellers</span>
          </div>
          <div class="stat">
            <span class="stat-number">8+</span>
            <span class="stat-label">Years of Experience</span>
          </div>
          <div class="stat">
            <span class="stat-number">100%</span>
            <span class="stat-label">Local Guides</span>
          </div>
        </div>
      </div>
      <div class="about-image-wrap">
        <img
          src="https://picsum.photos/seed/nosybe/600/500"
          alt="Scenic view of Nosy Be, Madagascar"
          class="about-image"
          loading="lazy"
        />
        <div class="about-badge-float">
          <span class="badge-icon">⭐</span>
          <span>Top-rated on Google</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TOURS -->
  <section class="section tours-section" id="tours">
    <div class="container">
      <span class="section-label">Our Tours</span>
      <h2 class="section-title">Unforgettable Experiences</h2>
      <p class="section-subtitle">
        Handcrafted tours designed to show you the very best of Madagascar's natural wonders,
        culture, and flavours.
      </p>

      <div class="tours-grid">
        {tours.map((tour) => (
          <article class="tour-card">
            <div class="tour-image-wrap">
              <img
                src={tour.images[0] ?? "https://picsum.photos/seed/madagascar/800/500"}
                alt={tour.title}
                class="tour-image"
                loading="lazy"
                onerror="this.src='https://picsum.photos/seed/madagascar/800/500'"
              />
              <div class="tour-price-badge">${tour.price} <span>USD</span></div>
            </div>
            <div class="tour-content">
              <h3 class="tour-title">{tour.title}</h3>
              <div class="tour-route">
                <span class="route-icon">📍</span>
                <span>{tour.startLocation}</span>
                <span class="route-arrow">→</span>
                <span>{tour.endLocation}</span>
              </div>
              <p class="tour-description">
                {tour.description.length > 160 ? tour.description.slice(0, 160) + "…" : tour.description}
              </p>
              <a
                href={`${whatsappUrl}?text=${encodeURIComponent(`Hello! I'd like to book the "${tour.title}" tour.`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary tour-btn"
              >
                💬 Book via WhatsApp
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section testimonials-section" id="testimonials">
    <div class="container">
      <span class="section-label">Testimonials</span>
      <h2 class="section-title">What Our Travellers Say</h2>
      <p class="section-subtitle">
        Don't just take our word for it — here's what guests from around the world have to say
        about their time with Nosy Be Tours.
      </p>

      <div class="testimonials-grid">
        {testimonials.map((t) => (
          <article class="testimonial-card">
            <div class="testimonial-stars">
              {"★".repeat(t.rating)}{"☆".repeat(5 - t.rating)}
            </div>
            <blockquote class="testimonial-text">"{t.text}"</blockquote>
            <div class="testimonial-author">
              <div class="author-avatar">{t.name.charAt(0)}</div>
              <div>
                <p class="author-name">{t.name}</p>
                <p class="author-country">🌍 {t.country}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-section" id="contact">
    <div class="container">
      <span class="section-label">Get in Touch</span>
      <h2 class="section-title">Ready to Start<br />Your Adventure?</h2>
      <p class="section-subtitle">
        Reach out to us on your preferred platform — we're always happy to answer questions,
        help plan your itinerary, or take a booking.
      </p>

      <div class="contact-cards">
        <a
          href={`${whatsappUrl}?text=${whatsappText}`}
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card contact-card--whatsapp"
        >
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
          </div>
          <div class="contact-info">
            <h3>WhatsApp</h3>
            <p>Chat with us instantly</p>
            <span class="contact-link-text">+261 34 000 0000 →</span>
          </div>
        </a>

        <a
          href="https://signal.me/#p/+261340000000"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card contact-card--signal"
        >
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2c5.514 0 10 4.486 10 10s-4.486 10-10 10S2 17.514 2 12 6.486 2 12 2zm-1.47 5.097l-.344.066a6.297 6.297 0 00-3.023 1.674 6.311 6.311 0 00-1.674 3.023 6.31 6.31 0 000 2.28 6.311 6.311 0 001.674 3.023 6.297 6.297 0 003.023 1.674 6.31 6.31 0 002.28 0 6.297 6.297 0 003.023-1.674 6.311 6.311 0 001.674-3.023l.066-.344-.793-.18-.066.307a5.5 5.5 0 01-1.462 2.643 5.5 5.5 0 01-2.643 1.462 5.5 5.5 0 01-1.988 0 5.5 5.5 0 01-2.643-1.462 5.5 5.5 0 01-1.462-2.643 5.5 5.5 0 010-1.988 5.5 5.5 0 011.462-2.643A5.5 5.5 0 0110.3 7.87l.307-.066-.18-.793z"/>
            </svg>
          </div>
          <div class="contact-info">
            <h3>Signal</h3>
            <p>Secure messaging</p>
            <span class="contact-link-text">@nosybetours →</span>
          </div>
        </a>

        <a
          href="https://maps.google.com/?cid=PLACEHOLDER"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card contact-card--google"
        >
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
          </div>
          <div class="contact-info">
            <h3>Google Business</h3>
            <p>Read our reviews</p>
            <span class="contact-link-text">Find us on Google →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(26,107,60,0.92) 0%, rgba(30,95,139,0.85) 100%),
      url('https://picsum.photos/seed/madagascar-beach/1600/900') center/cover no-repeat;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: white;
    padding-top: 80px;
    padding-bottom: 80px;
    max-width: 700px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.3);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    letter-spacing: 0.04em;
  }

  .hero-title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    color: white;
    margin-bottom: 1.25rem;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.88);
    max-width: 540px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.65);
    font-size: 0.8rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    z-index: 1;
    animation: fadeInUp 1s ease 1s both;
  }

  .scroll-arrow {
    font-size: 1.2rem;
    animation: bounce 1.5s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ABOUT */
  .about-section {
    background: var(--color-sand);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-text p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .about-stats {
    display: flex;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-green);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }

  .about-image-wrap {
    position: relative;
  }

  .about-image {
    width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    aspect-ratio: 6/5;
    object-fit: cover;
  }

  .about-badge-float {
    position: absolute;
    bottom: -1rem;
    left: -1rem;
    background: white;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-green);
  }

  .badge-icon {
    font-size: 1.2rem;
  }

  /* TOURS */
  .tours-section {
    background: var(--color-white);
  }

  .tours-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 2rem;
  }

  .tour-card {
    background: white;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    border: 1px solid rgba(0,0,0,0.06);
  }

  .tour-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .tour-image-wrap {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .tour-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .tour-card:hover .tour-image {
    transform: scale(1.04);
  }

  .tour-price-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-gold);
    color: white;
    padding: 0.4rem 0.9rem;
    border-radius: 9999px;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  }

  .tour-price-badge span {
    font-size: 0.7rem;
    font-weight: 500;
    opacity: 0.9;
  }

  .tour-content {
    padding: 1.5rem;
  }

  .tour-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-green-dark);
    margin-bottom: 0.5rem;
  }

  .tour-route {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .route-icon { font-size: 0.9rem; }
  .route-arrow { color: var(--color-gold); font-weight: 700; }

  .tour-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .tour-btn {
    width: 100%;
    justify-content: center;
  }

  /* TESTIMONIALS */
  .testimonials-section {
    background: var(--color-green-light);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .testimonial-card {
    background: white;
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow);
    border: 1px solid rgba(26,107,60,0.08);
    transition: transform 0.2s;
  }

  .testimonial-card:hover {
    transform: translateY(-2px);
  }

  .testimonial-stars {
    color: var(--color-gold);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .testimonial-text {
    font-style: italic;
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 0.93rem;
    quotes: none;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-green);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .author-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .author-country {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* CONTACT */
  .contact-section {
    background: var(--color-white);
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .contact-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 2rem;
    border-radius: var(--radius);
    border: 2px solid transparent;
    box-shadow: var(--shadow);
    text-decoration: none;
    transition: all 0.25s;
  }

  .contact-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .contact-card--whatsapp {
    background: #e9faf0;
    border-color: #25D366;
    color: #075E54;
  }

  .contact-card--whatsapp:hover {
    background: #d4f5e3;
  }

  .contact-card--signal {
    background: #eef2ff;
    border-color: #3a76f0;
    color: #1a3a8f;
  }

  .contact-card--signal:hover {
    background: #dce6ff;
  }

  .contact-card--google {
    background: #fff8f0;
    border-color: #ea4335;
    color: #7b2516;
  }

  .contact-card--google:hover {
    background: #ffe8e4;
  }

  .contact-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-info h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }

  .contact-info p {
    font-size: 0.85rem;
    opacity: 0.75;
    margin-bottom: 0.5rem;
  }

  .contact-link-text {
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-image-wrap {
      order: -1;
    }

    .about-badge-float {
      bottom: 0.5rem;
      left: 0.5rem;
    }

    .tours-grid {
      grid-template-columns: 1fr;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .contact-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
